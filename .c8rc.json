{
  "all": true,
  "include": ["taskpane/**/*.js", "scripts/**/*.js", "floating/**/*.js", "ribbon.js", "component.js"],
  "exclude": ["**/vendor/**", "**/node_modules/**", "tests/**", "wps-addon-build/**", "wps-addon-publish/**", "coverage/**"],
